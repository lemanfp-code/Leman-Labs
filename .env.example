# Clé API Anthropic (https://console.anthropic.com) — JAMAIS commitée
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Modèle Claude (claude-sonnet-4-6 recommandé : qualité/coût)
CLAUDE_MODEL=claude-sonnet-4-6

# Tokens max en sortie
CLAUDE_MAX_TOKENS=16000

# Modèle Whisper local (base, small, medium, large-v3)
WHISPER_MODEL=small

# Port du serveur local
PORT=8000

# Auth HTTP Basic — laisser vide en local, OBLIGATOIRE pour la mise en ligne
# Opérateur = toi : génère les synthèses (accès complet)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Visiteur = collaborateurs : consultation seule (voir/télécharger les
# dossiers, AUCUNE génération ni suppression). Identifiant partagé à l'équipe.
VIEWER_AUTH_USER=
VIEWER_AUTH_PASS=
